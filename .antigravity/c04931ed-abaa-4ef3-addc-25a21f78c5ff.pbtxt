    instruction: "Update Footer to use the logo and brand red"
    replacement_infos {
      original_chunk {
        target_content: "import { motion } from \"motion/react\";\nimport { ArrowUpRight } from \"lucide-react\";\n\nconst links = [\n  { name: \"About Us\", href: \"#\" },\n  { name: \"Contact\", href: \"#contact\" },\n  { name: \"Our Work\", href: \"#work\" },\n  { name: \"Insights\", href: \"#\" },\n  { name: \"Privacy Policy\", href: \"#\" }\n];\n\nexport function Footer() {\n  return (\n    <footer className=\"bg-black pt-24 md:pt-32 pb-8 px-4 md:px-6\" id=\"contact\">\n      <div className=\"max-w-7xl mx-auto\">\n        <div className=\"grid grid-cols-1 lg:grid-cols-2 gap-16 mb-24\">\n          <div>\n            <h2 className=\"text-5xl md:text-7xl font-display font-medium text-white mb-6 leading-tight max-w-lg\">\n              Let\342\200\231s build a brand people remember\n            </h2>\n            <p className=\"text-lg text-zinc-400 leading-relaxed max-w-md mb-10\">\n              If your brand needs better content, stronger visuals, smarter digital execution, or a complete growth-ready system \342\200\224 Brand Brick Studio is ready to build with you.\n            </p>\n            <div className=\"flex flex-col sm:flex-row gap-4\">\n              <a href=\"mailto:brandbrickstudio@gmail.com\" className=\"bg-white text-black px-8 py-4 rounded-full text-sm font-semibold hover:bg-zinc-200 transition-colors text-center inline-flex justify-center items-center\">\n                Book a Free Call\n              </a>\n              <a href=\"https://wa.me/917383386318\" className=\"bg-zinc-900 border border-zinc-800 text-white px-8 py-4 rounded-full text-sm font-semibold hover:bg-zinc-800 transition-colors text-center inline-flex justify-center items-center\">\n                Message Us on WhatsApp\n              </a>\n            </div>\n          </div>\n          \n          <div className=\"flex flex-col lg:items-end justify-start space-y-8\">\n            <div className=\"flex flex-col space-y-1 lg:items-end text-left lg:text-right\">\n              <span className=\"text-zinc-500 text-sm font-medium uppercase tracking-wider mb-1\">Email</span>\n              <a href=\"mailto:brandbrickstudio@gmail.com\" className=\"text-xl md:text-2xl text-white font-display hover:text-zinc-300 transition-colors inline-flex lg:justify-end items-center gap-2 group\">\n                brandbrickstudio@gmail.com\n                <ArrowUpRight size={20} className=\"text-zinc-500 group-hover:text-white transition-colors\" />\n              </a>\n            </div>\n            \n            <div className=\"flex flex-col space-y-1 lg:items-end text-left lg:text-right\">\n              <span className=\"text-zinc-500 text-sm font-medium uppercase tracking-wider mb-1\">Phone</span>\n              <a href=\"tel:+917383386318\" className=\"text-xl md:text-2xl text-white font-display hover:text-zinc-300 transition-colors\">\n                +91 7383386318\n              </a>\n            </div>\n\n            <div className=\"flex flex-col space-y-1 lg:items-end text-left lg:text-right\">\n              <span className=\"text-zinc-500 text-sm font-medium uppercase tracking-wider mb-1\">Instagram</span>\n              <a href=\"#\" className=\"text-xl md:text-2xl text-white font-display hover:text-zinc-300 transition-colors inline-flex lg:justify-end items-center gap-2 group\">\n                @brandbrickstudio\n                <ArrowUpRight size={20} className=\"text-zinc-500 group-hover:text-white transition-colors\" />\n              </a>\n            </div>\n\n            <div className=\"flex flex-col space-y-1 lg:items-end text-left lg:text-right\">\n              <span className=\"text-zinc-500 text-sm font-medium uppercase tracking-wider mb-1\">Location</span>\n              <span className=\"text-xl md:text-2xl text-white font-display\">\n                Silvassa, India\n              </span>\n            </div>\n          </div>\n        </div>\n\n        <div className=\"flex flex-col md:flex-row justify-between items-start md:items-center gap-8 border-t border-zinc-900 pt-8\">\n          <div className=\"flex flex-wrap gap-x-8 gap-y-4\">\n            {links.map((link, i) => (\n              <a key={i} href={link.href} className=\"text-sm font-medium text-zinc-400 hover:text-white transition-colors\">\n                {link.name}\n              </a>\n            ))}\n          </div>\n          <div className=\"text-left md:text-right\">\n            <p className=\"text-sm text-zinc-500 font-medium\">Proudly built in India.</p>\n            <p className=\"text-sm text-zinc-400 font-medium mt-1\">Built to stand out. Created for growth.</p>\n          </div>\n        </div>\n      </div>\n    </footer>\n  );\n}"
        replacement_content: "import { motion } from \"motion/react\";\nimport { ArrowUpRight, Mail, Instagram, MapPin } from \"lucide-react\";\n\nconst links = [\n  { name: \"About Us\", href: \"#\" },\n  { name: \"Contact\", href: \"#contact\" },\n  { name: \"Our Work\", href: \"#work\" },\n  { name: \"Insights\", href: \"#\" },\n  { name: \"Privacy Policy\", href: \"#\" }\n];\n\nexport function Footer() {\n  return (\n    <footer className=\"bg-[#020202] pt-24 md:pt-32 pb-8 px-4 md:px-6 border-t border-zinc-900 relative\" id=\"contact\">\n      <div className=\"absolute top-0 left-1/2 -translate-x-1/2 w-[80%] h-px bg-gradient-to-r from-transparent via-brand/50 to-transparent\"></div>\n      \n      <div className=\"max-w-7xl mx-auto\">\n        <div className=\"grid grid-cols-1 lg:grid-cols-2 gap-16 mb-24\">\n          <div>\n            <span className=\"inline-block px-4 py-1.5 rounded-full border border-zinc-800 bg-zinc-900/50 text-brand text-xs font-bold tracking-widest uppercase mb-8\">\n              Start Your Project\n            </span>\n            <h2 className=\"text-5xl md:text-7xl font-display font-bold text-white mb-6 leading-tight max-w-lg\">\n              Let\342\200\231s build a brand people remember\n            </h2>\n            <p className=\"text-lg text-zinc-400 leading-relaxed max-w-md mb-10\">\n              If your brand needs better content, stronger visuals, smarter digital execution, or a complete growth-ready system \342\200\224 Brand Brick Studio is ready to build with you.\n            </p>\n            <div className=\"flex flex-col sm:flex-row gap-4\">\n              <a href=\"mailto:brandbrickstudio@gmail.com\" className=\"bg-brand text-white px-8 py-4 rounded-full text-sm font-bold uppercase tracking-wider hover:bg-brand-hover transition-colors text-center inline-flex justify-center items-center shadow-[0_0_20px_rgba(220,38,38,0.3)]\">\n                Book a Free Call\n              </a>\n              <a href=\"https://wa.me/917383386318\" className=\"bg-transparent border-2 border-zinc-800 text-white px-8 py-4 rounded-full text-sm font-bold uppercase tracking-wider hover:border-brand/50 hover:bg-brand/5 transition-colors text-center inline-flex justify-center items-center\">\n                Message Us on WhatsApp\n              </a>\n            </div>\n          </div>\n          \n          <div className=\"flex flex-col lg:items-end justify-start space-y-12\">\n            <div className=\"hidden lg:flex flex-col space-y-1 lg:items-end text-left lg:text-right mb-4\">\n              <span className=\"font-display font-bold text-3xl tracking-tighter text-white\">\n                Brand <span className=\"text-brand\">Brick</span>\n              </span>\n              <span className=\"text-xs font-bold tracking-[0.2em] text-zinc-500 uppercase mt-1\">Studio</span>\n            </div>\n\n            <div className=\"flex flex-col space-y-1 lg:items-end text-left lg:text-right group\">\n              <span className=\"text-zinc-500 text-xs font-bold uppercase tracking-widest mb-2 flex items-center gap-2 lg:flex-row-reverse\" >\n                <Mail size={14} className=\"group-hover:text-brand transition-colors\" /> Email\n              </span>\n              <a href=\"mailto:brandbrickstudio@gmail.com\" className=\"text-xl md:text-2xl text-white font-display font-medium hover:text-brand transition-colors\">\n                brandbrickstudio@gmail.com\n              </a>\n            </div>\n            \n            <div className=\"flex flex-col space-y-1 lg:items-end text-left lg:text-right group\">\n               <span className=\"text-zinc-500 text-xs font-bold uppercase tracking-widest mb-2 flex items-center gap-2 lg:flex-row-reverse\">\n                <Instagram size={14} className=\"group-hover:text-brand transition-colors\" /> Instagram\n              </span>\n              <a href=\"#\" className=\"text-xl md:text-2xl text-white font-display font-medium hover:text-brand transition-colors\">\n                @brandbrickstudio\n              </a>\n            </div>\n\n            <div className=\"flex flex-col space-y-1 lg:items-end text-left lg:text-right group\">\n              <span className=\"text-zinc-500 text-xs font-bold uppercase tracking-widest mb-2 flex items-center gap-2 lg:flex-row-reverse\">\n                <MapPin size={14} className=\"group-hover:text-brand transition-colors\" /> Location\n              </span>\n              <span className=\"text-xl md:text-2xl text-white font-display font-medium\">\n                Silvassa, India\n              </span>\n            </div>\n          </div>\n        </div>\n\n        <div className=\"flex flex-col md:flex-row justify-between items-start md:items-center gap-8 border-t border-zinc-900 pt-8\">\n          <div className=\"flex flex-wrap gap-x-8 gap-y-4\">\n            {links.map((link, i) => (\n              <a key={i} href={link.href} className=\"text-sm font-medium text-zinc-500 hover:text-white transition-colors\">\n                {link.name}\n              </a>\n            ))}\n          </div>\n          <div className=\"text-left md:text-right\">\n            <p className=\"text-sm text-zinc-500 font-medium\">Proudly built in India.</p>\n            <p className=\"text-sm text-zinc-500 font-medium mt-1\">Built to <span className=\"text-zinc-400\">stand out.</span> Created for <span className=\"text-zinc-400\">growth.</span></p>\n          </div>\n        </div>\n      </div>\n    </footer>\n  );\n}"
      }
