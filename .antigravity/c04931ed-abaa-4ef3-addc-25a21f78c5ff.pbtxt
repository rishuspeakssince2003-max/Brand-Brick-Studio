    file_change_type: FILE_CHANGE_TYPE_CREATE
    replacement_chunks {
      replacement_content: "import { useState, useEffect } from \"react\";\nimport { Menu, X } from \"lucide-react\";\nimport { motion, AnimatePresence } from \"motion/react\";\n\nconst navLinks = [\n  { name: \"Our Work\", href: \"#work\" },\n  { name: \"Creative Services\", href: \"#services\" },\n  { name: \"Web & Tech\", href: \"#services\" },\n  { name: \"Social & Ads\", href: \"#services\" },\n  { name: \"How We Work\", href: \"#work\" },\n  { name: \"Our Stack\", href: \"#stack\" },\n  { name: \"Insights\", href: \"#\" },\n  { name: \"Why Us\", href: \"#why-us\" },\n  { name: \"Results\", href: \"#\" },\n  { name: \"Team\", href: \"#\" },\n  { name: \"Blog\", href: \"#\" },\n  { name: \"Packages\", href: \"#packages\" },\n];\n\nexport function Navbar() {\n  const [isOpen, setIsOpen] = useState(false);\n  const [scrolled, setScrolled] = useState(false);\n\n  useEffect(() => {\n    const handleScroll = () => {\n      setScrolled(window.scrollY > 20);\n    };\n    window.addEventListener(\"scroll\", handleScroll);\n    return () => window.removeEventListener(\"scroll\", handleScroll);\n  }, []);\n\n  return (\n    <>\n      <nav\n        className={`sticky top-0 z-50 transition-all duration-300 w-full ${\n          scrolled ? \"bg-[#050505]/80 backdrop-blur-md border-b border-zinc-800 py-4\" : \"bg-transparent py-6\"\n        }`}\n      >\n        <div className=\"max-w-7xl mx-auto px-4 md:px-6 flex items-center justify-between\">\n          <a href=\"#\" className=\"flex-shrink-0 relative z-50\">\n            <span className=\"font-display font-bold text-xl tracking-tight uppercase\">\n              Brand<br/><span className=\"text-zinc-500\">Brick.</span>\n            </span>\n          </a>\n\n          <div className=\"hidden lg:flex flex-wrap justify-center items-center gap-x-6 gap-y-2 max-w-3xl mx-auto\">\n            {navLinks.map((link) => (\n              <a\n                key={link.name}\n                href={link.href}\n                className=\"text-xs font-medium text-zinc-400 hover:text-white transition-colors\"\n              >\n                {link.name}\n              </a>\n            ))}\n          </div>\n\n          <div className=\"hidden lg:flex flex-shrink-0\">\n            <a\n              href=\"#contact\"\n              className=\"bg-white text-black px-5 py-2.5 rounded-full text-sm font-medium hover:bg-zinc-200 transition-colors\"\n            >\n              Book a Call\n            </a>\n          </div>\n\n          <button\n            className=\"lg:hidden relative z-50 p-2 -mr-2 text-zinc-300 hover:text-white transition-colors\"\n            onClick={() => setIsOpen(!isOpen)}\n          >\n            {isOpen ? <X size={24} /> : <Menu size={24} />}\n          </button>\n        </div>\n      </nav>\n\n      <AnimatePresence>\n        {isOpen && (\n          <motion.div\n            initial={{ opacity: 0, y: -20 }}\n            animate={{ opacity: 1, y: 0 }}\n            exit={{ opacity: 0, y: -20 }}\n            className=\"fixed inset-0 z-40 bg-[#050505] pt-28 px-6 pb-6 overflow-y-auto\"\n          >\n            <div className=\"flex flex-col gap-6\">\n              {navLinks.map((link) => (\n                <a\n                  key={link.name}\n                  href={link.href}\n                  onClick={() => setIsOpen(false)}\n                  className=\"text-2xl font-display font-medium text-zinc-300 hover:text-white transition-colors border-b border-zinc-900 pb-4\"\n                >\n                  {link.name}\n                </a>\n              ))}\n              <a\n                href=\"#contact\"\n                onClick={() => setIsOpen(false)}\n                className=\"inline-block mt-4 bg-white text-black px-6 py-4 rounded-full text-center font-medium self-start w-full\"\n              >\n                Book a Call\n              </a>\n            </div>\n          </motion.div>\n        )}\n      </AnimatePresence>\n    </>\n  );\n}\n"
    }
