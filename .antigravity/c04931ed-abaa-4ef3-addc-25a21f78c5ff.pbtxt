    file_change_type: FILE_CHANGE_TYPE_CREATE
    replacement_chunks {
      replacement_content: "import { motion } from \"motion/react\";\n\nexport function Manifesto() {\n  return (\n    <section className=\"py-24 md:py-32 bg-zinc-950 px-4 md:px-6 border-y border-zinc-900\" id=\"why-us\">\n      <div className=\"max-w-7xl mx-auto\">\n        <div className=\"grid md:grid-cols-12 gap-12 md:gap-8\">\n          <div className=\"md:col-span-4\">\n            <h2 className=\"text-zinc-500 font-medium text-sm tracking-wider uppercase mb-4\">What defines us</h2>\n            <p className=\"text-2xl md:text-3xl font-display font-medium text-white max-w-sm leading-tight\">\n              Built for Growth. <br/>Designed for Results.\n            </p>\n          </div>\n          <div className=\"md:col-span-8 flex flex-col gap-16\">\n            <div className=\"prose prose-invert prose-lg max-w-none text-zinc-400\">\n              <p className=\"text-lg leading-relaxed mb-6\">\n                Brand Brick Studio works like an extended in-house team for ambitious brands. No scattered freelancers. No broken communication. No random execution.\n              </p>\n              <p className=\"text-lg leading-relaxed\">\n                Just one sharp team handling creative, content, strategy, tech, and growth together \342\200\224 so your brand stays consistent, fast, and effective.\n              </p>\n            </div>\n\n            <div className=\"border-l-2 border-zinc-700 pl-6 md:pl-10\">\n              <h3 className=\"text-2xl md:text-4xl font-display font-medium leading-tight text-white mb-8\">\n                We\342\200\231re brand builders at heart, creators by instinct, strategists by intent, and executors by speed.\n              </h3>\n              <p className=\"text-xl md:text-2xl text-zinc-400 leading-relaxed max-w-3xl mb-8\">\n                We believe modern brands don\342\200\231t need ten different vendors. They need one aligned team that can think, create, build, manage, and scale.\n              </p>\n              <p className=\"text-lg leading-relaxed text-zinc-500 max-w-2xl\">\n                That\342\200\231s why Brand Brick Studio brings content, design, video, websites, software, SEO, social media, ad creatives, and 3D design together under one roof \342\200\224 so every move feels connected, intentional, and built for growth.\n              </p>\n            </div>\n            \n            <div className=\"bg-zinc-900 p-8 rounded-2xl flex items-center justify-between gap-6 overflow-hidden relative\">\n               <div className=\"absolute inset-0 bg-gradient-to-r from-zinc-800/20 to-transparent pointer-events-none\" />\n               <p className=\"font-display text-lg md:text-xl text-white whitespace-nowrap animate-marquee\">\n                  One Team. Clear Strategy. Strong Creative. Fast Execution. Real Growth. <span className=\"text-zinc-600 px-4\">\342\200\242</span> \n                  One Team. Clear Strategy. Strong Creative. Fast Execution. Real Growth. <span className=\"text-zinc-600 px-4\">\342\200\242</span> \n               </p>\n            </div>\n          </div>\n        </div>\n      </div>\n\n      <style>{`\n        @keyframes marquee {\n          0% { transform: translateX(0); }\n          100% { transform: translateX(-50%); }\n        }\n        .animate-marquee {\n          animation: marquee 20s linear infinite;\n        }\n      `}</style>\n    </section>\n  );\n}\n"
    }
