  file_change {
    absolute_path_uri: "file:///src/components/LatestWork.tsx"
    file_change_type: FILE_CHANGE_TYPE_CREATE
    replacement_chunks {
      replacement_content: "import { ArrowUpRight } from \"lucide-react\";\nimport { motion } from \"motion/react\";\n\nconst capabilities = [\n  {\n    title: \"Scroll-Stopping Reels for Modern Brands\",\n    desc: \"Short-form content designed to grab attention and keep your brand top of mind.\"\n  },\n  {\n    title: \"High-Converting Ad Creatives\",\n    desc: \"Performance-focused visuals built for clicks, conversions, and campaign momentum.\"\n  },\n  {\n    title: \"Premium Social Media Branding\",\n    desc: \"Feed systems that look polished, feel consistent, and build trust instantly.\"\n  },\n  {\n    title: \"Websites That Look Sharp and Work Hard\",\n    desc: \"Fast, modern websites built to impress users and convert traffic into leads.\"\n  },\n  {\n    title: \"Landing Pages Built for Action\",\n    desc: \"Focused pages designed for launches, lead generation, and paid traffic campaigns.\"\n  },\n  {\n    title: \"Professional Video Shoots & Editing\",\n    desc: \"From shoot planning to polished final output \342\200\224 built to look premium on every screen.\"\n  },\n  {\n    title: \"Thumbnail Designs That Increase Clicks\",\n    desc: \"Attention-grabbing visuals made for creators, businesses, and video-first brands.\"\n  },\n  {\n    title: \"3D Interior Visuals That Sell the Vision\",\n    desc: \"Realistic spatial renders that help clients imagine the final experience before execution.\"\n  },\n  {\n    title: \"Content Systems That Remove Guesswork\",\n    desc: \"30-day content planning aligned with brand voice, offers, and platform goals.\"\n  },\n  {\n    title: \"Software & Workflow Solutions\",\n    desc: \"Custom builds, integrations, and practical systems that support business growth.\"\n  }\n];\n\nexport function LatestWork() {\n  return (\n    <section className=\"py-24 md:py-32 px-4 md:px-6 max-w-7xl mx-auto\" id=\"work\">\n      <div className=\"mb-16 md:mb-24 flex flex-col md:flex-row md:items-end justify-between gap-8\">\n        <div className=\"max-w-2xl\">\n          <h2 className=\"text-4xl md:text-5xl font-display font-medium text-white mb-4\">Our latest work</h2>\n          <p className=\"text-xl text-zinc-400\">What we create for brands that want to stand out, sell better, and grow faster.</p>\n        </div>\n        <a href=\"#services\" className=\"inline-flex items-center gap-2 text-sm font-medium text-white hover:text-zinc-300 transition-colors shrink-0 border-b border-white pb-1 group\">\n          Explore Our Capabilities \n          <ArrowUpRight size={16} className=\"group-hover:translate-x-0.5 group-hover:-translate-y-0.5 transition-transform\" />\n        </a>\n      </div>\n\n      <div className=\"grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6\">\n        {capabilities.map((item, i) => (\n          <motion.div \n            key={i}\n            initial={{ opacity: 0, y: 20 }}\n            whileInView={{ opacity: 1, y: 0 }}\n            viewport={{ once: true, margin: \"-100px\" }}\n            transition={{ duration: 0.5, delay: i * 0.05 }}\n            className=\"group block p-8 rounded-2xl bg-zinc-900/50 border border-zinc-800 hover:border-zinc-700 transition-colors\"\n          >\n            <div className=\"h-12 w-12 rounded-full bg-zinc-800 flex items-center justify-center mb-6 text-zinc-400 group-hover:text-white transition-colors group-hover:bg-zinc-700\">\n              <ArrowUpRight size={20} />\n            </div>\n            <h3 className=\"text-xl font-display font-medium text-white mb-3 leading-tight\">{item.title}</h3>\n            <p className=\"text-zinc-400 text-sm leading-relaxed\">{item.desc}</p>\n          </motion.div>\n        ))}\n      </div>\n      \n      <div className=\"mt-16 text-center\">\n        <a href=\"#contact\" className=\"inline-flex items-center justify-center bg-white text-black px-8 py-4 rounded-full text-sm font-semibold hover:bg-zinc-200 transition-colors\">\n          See What We Can Build\n        </a>\n      </div>\n    </section>\n  );\n}\n"
    }
