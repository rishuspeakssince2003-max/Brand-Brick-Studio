  file_change {
    absolute_path_uri: "file:///src/components/Services.tsx"
    file_change_type: FILE_CHANGE_TYPE_EDIT
    replacement_chunks {
      target_content: "import { motion } from \"motion/react\";\n\nconst services = [\n  { title: \"Video Editing\", desc: \"Raw footage ko polished brand-ready content me convert karna \342\200\224 reels, ads, promos, and social edits.\" },\n  { title: \"Video Shoot\", desc: \"On-site planning, camera execution, and production support for content that feels premium and intentional.\" },\n  { title: \"Reels Creation\", desc: \"Short-form vertical videos designed for reach, retention, and relevance on modern platforms.\" },\n  { title: \"Thumbnail Design\", desc: \"Bold, click-worthy thumbnail systems that improve attention and video performance.\" },\n  { title: \"Graphic Design\", desc: \"Brand assets, packaging, layouts, campaign creatives, and social visuals that look sharp and stay memorable.\" },\n  { title: \"Website Development\", desc: \"Modern, scalable websites built for speed, trust, and conversion.\" },\n  { title: \"3D Interior Design\", desc: \"High-quality realistic visualizations that help spaces sell before execution begins.\" },\n  { title: \"Software Development\", desc: \"Custom systems, CRM integrations, workflows, and practical digital solutions tailored to your business.\" },\n  { title: \"SEO Optimization\", desc: \"Search visibility strategies that help your brand get discovered organically.\" },\n  { title: \"Social Media Management\", desc: \"Planning, posting, coordination, and brand consistency across your social presence.\" },\n  { title: \"Content Strategy\", desc: \"Structured 30-day content thinking built around brand voice, audience behavior, and growth goals.\" },\n  { title: \"Ad Creatives for Meta\", desc: \"Conversion-focused banners, concepts, and designs made to support ad performance.\" }\n];\n\nexport function Services() {\n  return (\n    <section className=\"py-24 md:py-32 bg-[#0a0a0a] border-y border-zinc-900 px-4 md:px-6\" id=\"services\">\n      <div className=\"max-w-7xl mx-auto\">\n        <div className=\"mb-20 max-w-3xl\">\n          <h2 className=\"text-4xl md:text-5xl font-display font-medium text-white mb-6\">Our services</h2>\n          <p className=\"text-xl md:text-2xl text-zinc-400 font-light leading-relaxed\">\n            Everything your brand needs \342\200\224 creative, content, digital, and technical execution in one place.\n          </p>\n        </div>\n\n        <div className=\"grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-x-8 gap-y-12\">\n          {services.map((service, i) => (\n            <div key={i} className=\"flex flex-col group border-t border-zinc-800 pt-6 mt-2\">\n              <span className=\"text-zinc-600 font-mono text-xs mb-4 block\">{(i + 1).toString().padStart(2, \'0\')}</span>\n              <h3 className=\"text-lg font-display font-medium text-white mb-3 group-hover:text-zinc-300 transition-colors\">{service.title}</h3>\n              <p className=\"text-zinc-400 text-sm leading-relaxed\">{service.desc}</p>\n            </div>\n          ))}\n        </div>\n\n        <div className=\"mt-24 pt-12 border-t border-zinc-800\">\n          <p className=\"text-lg md:text-xl text-zinc-300 font-medium max-w-4xl tracking-tight leading-relaxed\">\n            From first impression to final conversion, Brand Brick Studio helps brands look better, communicate stronger, and grow smarter.\n          </p>\n        </div>\n      </div>\n    </section>\n  );\n}"
      replacement_content: "import { motion } from \"motion/react\";\nimport { PlaySquare, Camera, Clapperboard, Image as ImageIcon, PenTool, Globe, Box, Code, TrendingUp, Heart, Lightbulb, Megaphone } from \"lucide-react\";\n\nconst services = [\n  { title: \"Video Editing\", desc: \"Raw footage ko polished brand-ready content me convert karna \342\200\224 reels, ads, promos, and social edits.\", icon: PlaySquare },\n  { title: \"Video Shoot\", desc: \"On-site planning, camera execution, and production support for content that feels premium and intentional.\", icon: Camera },\n  { title: \"Reels Creation\", desc: \"Short-form vertical videos designed for reach, retention, and relevance on modern platforms.\", icon: Clapperboard },\n  { title: \"Thumbnail Design\", desc: \"Bold, click-worthy thumbnail systems that improve attention and video performance.\", icon: ImageIcon },\n  { title: \"Graphic Design\", desc: \"Brand assets, packaging, layouts, campaign creatives, and social visuals that look sharp and stay memorable.\", icon: PenTool },\n  { title: \"Website Development\", desc: \"Modern, scalable websites built for speed, trust, and conversion.\", icon: Globe },\n  { title: \"3D Interior Design\", desc: \"High-quality realistic visualizations that help spaces sell before execution begins.\", icon: Box },\n  { title: \"Software Development\", desc: \"Custom systems, CRM integrations, workflows, and practical digital solutions tailored to your business.\", icon: Code },\n  { title: \"SEO Optimization\", desc: \"Search visibility strategies that help your brand get discovered organically.\", icon: TrendingUp },\n  { title: \"Social Media Management\", desc: \"Planning, posting, coordination, and brand consistency across your social presence.\", icon: Heart },\n  { title: \"Content Strategy\", desc: \"Structured 30-day content thinking built around brand voice, audience behavior, and growth goals.\", icon: Lightbulb },\n  { title: \"Ad Creatives for Meta\", desc: \"Conversion-focused banners, concepts, and designs made to support ad performance.\", icon: Megaphone }\n];\n\nexport function Services() {\n  return (\n    <section className=\"py-24 md:py-32 bg-[#050505] border-y border-zinc-900 px-4 md:px-6\" id=\"services\">\n      <div className=\"max-w-7xl mx-auto\">\n        <div className=\"mb-20 max-w-3xl text-center mx-auto\">\n          <h2 className=\"text-4xl md:text-5xl font-display font-medium text-brand uppercase tracking-wider mb-6\">Our Services</h2>\n          <p className=\"text-xl md:text-2xl text-zinc-300 font-light leading-relaxed\">\n            Everything your brand needs \342\200\224 creative, content, digital, and technical execution in one place.\n          </p>\n        </div>\n\n        <div className=\"grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6\">\n          {services.map((service, i) => {\n            const Icon = service.icon;\n            return (\n              <div key={i} className=\"flex flex-col items-center text-center p-8 border-2 border-zinc-800 rounded-3xl bg-black hover:border-brand transition-colors group\">\n                <div className=\"mb-6 h-16 flex items-center justify-center\">\n                  <Icon size={48} strokeWidth={1.5} className=\"text-white group-hover:text-brand transition-colors\" />\n                </div>\n                <h3 className=\"text-lg font-display font-bold uppercase tracking-wide text-white mb-4\">{service.title}</h3>\n                <p className=\"text-zinc-400 text-sm leading-relaxed\">{service.desc}</p>\n              </div>\n            );\n          })}\n        </div>\n\n        <div className=\"mt-20 flex justify-center\">\n          <div className=\"inline-flex flex-col md:flex-row divide-y md:divide-y-0 md:divide-x divide-zinc-800 border-2 border-zinc-800 rounded-3xl overflow-hidden p-2 bg-black items-center max-w-4xl w-full\">\n            <div className=\"flex-1 p-6 flex flex-col items-center text-center\">\n               <span className=\"text-brand font-bold text-lg uppercase tracking-wider mb-2 flex items-center gap-2\">Built For Growth.</span>\n            </div>\n             <div className=\"flex-1 p-6 flex flex-col items-center text-center\">\n               <span className=\"text-brand font-bold text-lg uppercase tracking-wider mb-2 flex items-center gap-2\">Designed For Results.</span>\n            </div>\n             <div className=\"flex-1 p-6 flex flex-col items-center text-center\">\n               <span className=\"text-brand font-bold text-lg uppercase tracking-wider mb-2 flex items-center gap-2\">One Team. Everything.</span>\n            </div>\n          </div>\n        </div>\n      </div>\n    </section>\n  );\n}"
    }
