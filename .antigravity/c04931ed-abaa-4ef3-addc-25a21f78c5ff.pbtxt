    replacement_chunks {
      target_content: "      <div className=\"mb-16 md:mb-20 text-center max-w-3xl mx-auto\">\n        <h2 className=\"text-zinc-500 font-medium text-sm tracking-wider uppercase mb-4\">Packages</h2>\n        <h3 className=\"text-4xl md:text-5xl font-display font-medium text-white mb-6\">Built for different stages of growth</h3>\n        <p className=\"text-xl text-zinc-400\">Simple plans. Clear deliverables. Real execution.</p>\n      </div>\n\n      <div className=\"grid grid-cols-1 lg:grid-cols-3 gap-6 mb-12\">\n        {packages.map((pkg, i) => (\n          <div \n            key={i} \n            className={`relative flex flex-col p-8 rounded-3xl border ${\n              pkg.popular \n                ? \"bg-zinc-900 border-zinc-700\" \n                : \"bg-zinc-950 border-zinc-800\"\n            }`}\n          >\n            {pkg.popular && (\n              <div className=\"absolute -top-4 left-1/2 -translate-x-1/2 bg-white text-black px-4 py-1.5 rounded-full text-xs font-bold uppercase tracking-wider uppercase\">\n                Most Popular\n              </div>\n            )}\n            <div className=\"mb-8\">\n              <h4 className=\"text-xl font-display font-medium text-white mb-2\">{pkg.name}</h4>\n              <div className=\"flex items-baseline gap-1 mb-4\">\n                <span className=\"text-4xl font-display font-bold text-white\">{pkg.price}</span>\n                <span className=\"text-zinc-500\">{pkg.period}</span>\n              </div>\n              <p className=\"text-sm text-zinc-400 h-16\">{pkg.desc}</p>\n            </div>\n            \n            <div className=\"flex-grow mb-8 line-clamp-none\">\n              <p className=\"text-xs font-semibold text-zinc-300 uppercase tracking-wider mb-4\">Includes</p>\n              <ul className=\"space-y-4\">\n                {pkg.features.map((feature, idx) => (\n                  <li key={idx} className=\"flex items-start gap-3 text-sm text-zinc-300\">\n                    <Check size={16} className=\"text-white shrink-0 mt-0.5\" />\n                    <span className=\"leading-tight\">{feature}</span>\n                  </li>\n                ))}\n              </ul>\n            </div>\n            \n            <a \n              href=\"#contact\" \n              className={`w-full py-4 rounded-full text-sm font-semibold text-center transition-colors ${\n                pkg.popular \n                  ? \"bg-white text-black hover:bg-zinc-200\" \n                  : \"bg-zinc-800 text-white hover:bg-zinc-700\"\n              }`}\n            >\n              {pkg.cta}\n            </a>\n          </div>\n        ))}\n      </div>"
      replacement_content: "      <div className=\"mb-16 md:mb-20 text-center max-w-3xl mx-auto\">\n        <h2 className=\"text-brand font-bold text-sm tracking-widest uppercase mb-4\">Packages</h2>\n        <h3 className=\"text-4xl md:text-5xl font-display font-medium text-white mb-6\">Built for different stages of growth</h3>\n        <p className=\"text-xl text-zinc-400\">Simple plans. Clear deliverables. Real execution.</p>\n      </div>\n\n      <div className=\"grid grid-cols-1 lg:grid-cols-3 gap-6 mb-12\">\n        {packages.map((pkg, i) => (\n          <div \n            key={i} \n            className={`relative flex flex-col p-8 rounded-3xl border-2 ${\n              pkg.popular \n                ? \"bg-zinc-900 border-brand shadow-[0_0_30px_rgba(220,38,38,0.15)]\" \n                : \"bg-black border-zinc-800\"\n            }`}\n          >\n            {pkg.popular && (\n              <div className=\"absolute -top-4 left-1/2 -translate-x-1/2 bg-brand text-white px-5 py-1.5 rounded-full text-xs font-bold uppercase tracking-wider shadow-lg shadow-brand/50\">\n                Most Popular\n              </div>\n            )}\n            <div className=\"mb-8\">\n              <h4 className={`text-xl font-display font-bold uppercase tracking-wider mb-2 ${pkg.popular ? \"text-brand\" : \"text-white\"}`}>{pkg.name}</h4>\n              <div className=\"flex items-baseline gap-1 mb-4\">\n                <span className=\"text-4xl font-display font-bold text-white\">{pkg.price}</span>\n                <span className=\"text-zinc-500\">{pkg.period}</span>\n              </div>\n              <p className=\"text-sm text-zinc-400 h-16\">{pkg.desc}</p>\n            </div>\n            \n            <div className=\"flex-grow mb-8 line-clamp-none\">\n              <p className=\"text-xs font-semibold text-zinc-500 uppercase tracking-wider mb-4 border-b border-zinc-800 pb-2\">Includes</p>\n              <ul className=\"space-y-4\">\n                {pkg.features.map((feature, idx) => (\n                  <li key={idx} className=\"flex items-start gap-3 text-sm text-zinc-300\">\n                    <Check size={16} className={`shrink-0 mt-0.5 ${pkg.popular ? \"text-brand\" : \"text-white\"}`} />\n                    <span className=\"leading-tight\">{feature}</span>\n                  </li>\n                ))}\n              </ul>\n            </div>\n            \n            <a \n              href=\"#contact\" \n              className={`w-full py-4 rounded-full text-sm font-bold tracking-wider uppercase text-center transition-colors ${\n                pkg.popular \n                  ? \"bg-brand text-white hover:bg-brand-hover\" \n                  : \"bg-zinc-900 text-white hover:bg-zinc-800 border-2 border-zinc-800\"\n              }`}\n            >\n              {pkg.cta}\n            </a>\n          </div>\n        ))}\n      </div>"
